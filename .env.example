# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (.env ไม่ควร commit เข้า git)

# ข้อมูลล็อกอิน MT5 (ใช้ตอนดึงข้อมูลย้อนหลังผ่าน data/mt5_loader.py)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# การตั้งค่าตลาด/กลยุทธ์
SYMBOL=XAUUSD
TIMEFRAME=H1
START_DATE=2023-01-01
END_DATE=2026-07-01

# การจัดการความเสี่ยง
INITIAL_BALANCE=10000
RISK_PER_TRADE_PCT=1.0
MAX_DRAWDOWN_PCT=20.0

# ต้นทุนจำลอง (หน่วย points)
SPREAD_POINTS=30
SLIPPAGE_POINTS=5

# ไฟล์ SQLite เก็บ log ทุก signal/decision/trade (ตามรอยย้อนกลับได้)
LOG_DB_PATH=trading_log.db
