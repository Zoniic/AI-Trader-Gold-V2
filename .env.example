# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (.env ไม่ควร commit เข้า git)

# ข้อมูลล็อกอิน MT5 (ใช้ตอนดึงข้อมูลย้อนหลังผ่าน data/mt5_loader.py)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# การตั้งค่าตลาด/กลยุทธ์
SYMBOL=XAUUSD
TIMEFRAME=H1
START_DATE=2023-01-01
END_DATE=2026-07-01

# การจัดการความเสี่ยง
INITIAL_BALANCE=10000
RISK_PER_TRADE_PCT=1.0
MAX_DRAWDOWN_PCT=20.0

# ต้นทุนจำลอง (หน่วย points)
SPREAD_POINTS=30
SLIPPAGE_POINTS=5

# ไฟล์ SQLite เก็บ log ทุก signal/decision/trade (ตามรอยย้อนกลับได้)
LOG_DB_PATH=trading_log.db

# Discord webhook สำหรับแจ้งเตือน (เปิดไม้/ปิดไม้/kill-switch/error/start-stop)
# สร้างได้ที่ Discord: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
# แยก 2 ตัวตั้งใจ — live กับ dry-run/backtest ยิงคนละช่อง กันข้อความปนกันจนแยกไม่ออกว่าเงินจริงหรือทดสอบ
# ไม่ตั้งค่า = ไม่มีการแจ้งเตือน (แต่ระบบยังทำงานปกติ ไม่ error)
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_URL_DRY_RUN=

# Instrument spec ต่อสินทรัพย์ (ดีฟอลต์ = GOLD) — ถ้ารัน backtest/live สินทรัพย์อื่นต้องตั้งให้ตรงโบรก
# ตัวอย่าง EURUSD: POINT_VALUE=0.00001 CONTRACT_SIZE=100000 SPREAD_POINTS=15
POINT_VALUE=0.01
CONTRACT_SIZE=100
