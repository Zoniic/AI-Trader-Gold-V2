{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dashboard",
      "runtimeExecutable": "streamlit",
      "runtimeArgs": ["run", "dashboard.py", "--server.headless", "true"],
      "port": 8501
    },
    {
      "name": "api-backend",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["web.backend.main:app", "--host", "127.0.0.1", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "web-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web/frontend", "run", "dev", "--", "--port", "3100"],
      "port": 3100
    }
  ]
}
